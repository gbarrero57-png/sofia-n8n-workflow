PORT=3001
LOG_LEVEL=info

# Playwright
BROWSER_HEADLESS=true
SCRAPER_RATE_LIMIT_MS=2500
SCRAPER_PAGE_TIMEOUT_MS=30000
SCRAPER_MAX_PAGES=500

# n8n callback (opcional — para notificar cuando termina el scraping)
N8N_CALLBACK_URL=https://workflows.n8n.redsolucionesti.com/webhook/remaju-done

# Telegram (para alertas de error del scraper al admin)
ADMIN_TELEGRAM_TOKEN=
ADMIN_TELEGRAM_CHAT_ID=

# DB path
DB_PATH=../data/remaju.db
